{
    "dirs": {
        "vanguard": "/root/vanguard",
        "jaguar": "/root/vanguard/jaguar"
    },
    "steps": {
        "full": [
            {
                "text": "git pull"
            },
            {
                "text": "Get build merges",
                "command": "jaguar/tools/cicd/get_build_merges.sh -v | tee /tmp/changes.txt"
            },
            {
                "text": "git status (fail if changes)",
                "command": "s=\"$(git status --porcelain)\"; if [ -n \"$s\" ]; then echo \"$s\"; echo \"Uncommitted changes detected\"; exit 1; else echo \"Working tree clean\"; fi"
            },
            {
                "text": "git pull"
            },
            {
                "text": "Make",
                "command": "./make.sh current",
                "help": "Runs ./make.sh current"
            },
            {
                "text": "git diff",
                "help": "You should only see changes to api.json and version files"
            },
            {
                "text": "Commit version changes",
                "command": "git commit -a -m \"rc build\" && git push"
            },
            {
                "text": "Promote to rc",
                "command": "./promote.sh latest rc",
                "input": "y\nn\n"
            },
            {
                "text": "Deploy to rc",
                "command": "cluster/tools/reroll_namespace_all.sh rc -j 3 --one"
            },
            {
                "help": "TEST PRODUCT FUNCTIONALITY ON RC SWIMLANE"
            },
            {
                "text": "Run playwright tests",
                "command": "docker run -it --rm --name playwright-headless --ipc=host -v /tmp/.X11-unix:/tmp/.X11-unix -v ~/vanguard:/vanguard mcr.microsoft.com/playwright:v1.56.1-noble /bin/bash -c \"cd /vanguard/e2e && npx playwright test --config playwright.all.config.ts -j 5\"",
                "on_error": [
                    "echo \"Playwright tests failed!\"",
                    "echo \"After docker starts up, run this on your computer: ssh -C -L 9323:localhost:9323 build-box\"",
                    "echo \"Then open http://localhost:9323 in your browser\"",
                    "docker run -it --rm --name playwright-headless --ipc=host -v /tmp/.X11-unix:/tmp/.X11-unix -p 9323:9323 -v ~/vanguard:/vanguard mcr.microsoft.com/playwright:v1.56.1-noble /bin/bash -c \"cd /vanguard/e2e && npx playwright show-report --host 0.0.0.0\""
                ]
            },
            {
                "text": "Promote to prod",
                "command": "./promote.sh latest prod",
                "input": "y\nn\n"
            },
            {
                "text": "Deploy to prod",
                "command": "cluster/tools/reroll_namespace_all.sh prod -j 2 --one"
            },
            {
                "text": "Promote to dev",
                "command": "./promote.sh latest dev",
                "input": "y\nn\n"
            },
            {
                "text": "Deploy to dev",
                "command": "cluster/tools/reroll_namespace_all.sh dev -j 2 --one"
            },
            {
                "text": "Promote to staging",
                "command": "./promote.sh latest staging",
                "input": "y\nn\n"
            },
            {
                "text": "Deploy to staging",
                "command": "cluster/tools/reroll_namespace_all.sh staging -j 2 --one"
            },
            {
                "text": "Rotate all images",
                "command": "rotate-all-images-wrapper.sh"
            }
        ],
        "backend": [
            {
                "text": "git pull"
            },
            {
                "text": "Get build merges",
                "command": "jaguar/tools/cicd/get_build_merges.sh -v | tee /tmp/changes.txt"
            },
            {
                "text": "git status (fail if changes)",
                "command": "s=\"$(git status --porcelain)\"; if [ -n \"$s\" ]; then echo \"$s\"; echo \"Uncommitted changes detected\"; exit 1; else echo \"Working tree clean\"; fi"
            },
            {
                "text": "git pull"
            },
            {
                "text": "Make",
                "command": "cd jaguar ; ./make.sh current",
                "help": "Runs cd jaguar ; ./make.sh current"
            },
            {
                "text": "Promote to rc",
                "command": "./promote.sh latest rc",
                "input": "y\nn\n"
            },
            {
                "text": "Deploy to rc",
                "command": "cluster/tools/reroll_namespace_all.sh rc -j 3 --one"
            },
            {
                "text": "Promote to prod",
                "command": "./promote.sh latest prod",
                "input": "y\nn\n"
            },
            {
                "text": "Deploy to prod",
                "command": "cluster/tools/reroll_namespace_all.sh prod -j 2 --one"
            },
            {
                "text": "Promote to dev",
                "command": "./promote.sh latest dev",
                "input": "y\nn\n"
            },
            {
                "text": "Deploy to dev",
                "command": "cluster/tools/reroll_namespace_all.sh dev -j 2 --one"
            },
            {
                "text": "Promote to staging",
                "command": "./promote.sh latest staging",
                "input": "y\nn\n"
            },
            {
                "text": "Deploy to staging",
                "command": "cluster/tools/reroll_namespace_all.sh staging -j 2 --one"
            },
            {
                "text": "Rotate all images",
                "command": "rotate-all-images-wrapper.sh"
            }
        ]
    }
}
