{
    "settings": {
        "build_directory": "/root/vanguard",
        "build_name": "test"
    },
    "steps": {
        "full": [
            {
                "text": "git pull"
            },
            {
                "text": "./generate_error.sh",
                "on_error": [
                    "echo \"Error generated line 1!\"",
                    "echo \"Error generated line 2!\"",
                    "echo \"Error generated line 3!\"",
                    "echo \"Error generated line 4!\""
                ]
            },
            {
                "text": "test awk",
                "command": "awk '/\\^{52}/{found=1; next} found && /^-{36}$/{exit} found' {{TMPDIR}}/changes.txt",
                "comment": "The awk command is used to extract the build merges from the changes.txt file. It copies everything after 52 ^ characters and up to 36 - characters."
            },
            {
                "text": "Get build merges",
                "command": "jaguar/tools/cicd/get_build_merges.sh -v | tee {{TMPDIR}}/changes.txt"
            },
            {
                "text": "git status"
            },
            {
                "text": "Promote to rc",
                "command": "./promote.sh latest rc",
                "input": "y\nn\n"
            },
            {
                "text": "Deploy to rc",
                "command": "cluster/tools/reroll_namespace_all.sh rc -j 3 --one"
            }
        ],
        "backend": [
            {
                "text": "git pull"
            },
            {
                "text": "Get build merges",
                "command": "jaguar/tools/cicd/get_build_merges.sh -v | tee {{TMPDIR}}/changes.txt"
            }
        ]
    }
}
